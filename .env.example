# Django Configuration
SECRET_KEY=your-secret-key-here
DEBUG=True

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ISSUER=persona-api
JWT_AUDIENCE=persona-web

# Database Configuration (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/_db

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@caldasdev.store

# Resend API Configuration (Recommended for production)
RESEND_API_KEY=api-key

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Google OAuth2 Configuration
GOOGLE_OAUTH2_KEY=your-google-client-id
GOOGLE_OAUTH2_SECRET=your-google-client-secret

# GitHub OAuth2 Configuration
GITHUB_KEY=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Other
OPEN_API=your-openai-api-key
